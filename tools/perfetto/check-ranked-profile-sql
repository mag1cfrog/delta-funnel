#!/usr/bin/env bash
set -euo pipefail

script_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)
sql_dir=$script_dir/../../crates/delta-funnel/src/perfetto_profile/sql
trace_processor=${TRACE_PROCESSOR_SHELL:-trace_processor_shell}
if ! command -v "$trace_processor" >/dev/null 2>&1; then
  printf 'check-ranked-profile-sql: required command is unavailable: %s\n' \
    "$trace_processor" >&2
  exit 127
fi

output=$({
  sed -n '1,$p' "$sql_dir/sample_correlation.sql"
  sed -n '1,$p' "$sql_dir/ranked_profile_base.sql"
  sed -n '1,$p' "$script_dir/ranked-profile.sql"
  printf '%s\n' \
    "CREATE PERFETTO TABLE delta_funnel_capture_health AS" \
    "SELECT 1 AS capture_complete, 1 AS semantic_complete;"
  sed -n '1,$p' "$sql_dir/ranked_report.sql"
  sed -n '1,$p' "$script_dir/ranked-profile-fixture.sql"
} | "$trace_processor" query --query-file - /dev/null)
printf '%s\n' "$output"

fixture_error_count=${output##*,}
if [[ ! $fixture_error_count =~ ^[0-9]+$ ]]; then
  printf 'check-ranked-profile-sql: unexpected fixture result\n' >&2
  exit 65
fi
if (( fixture_error_count != 0 )); then
  printf 'check-ranked-profile-sql: %s fixture checks failed\n' \
    "$fixture_error_count" >&2
  exit 65
fi
