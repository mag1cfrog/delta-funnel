#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf 'Usage: %s WHEEL\n' "$0"
}

if [[ ${1:-} == --help || ${1:-} == -h ]]; then
  usage
  exit 0
fi
if (( $# != 1 )); then
  usage >&2
  exit 64
fi

wheel=$1
python=${PYTHON:-python3}
max_wheel_bytes=100000000

if [[ ! -f $wheel || ! -r $wheel ]]; then
  printf 'check-diagnostics-wheel: wheel is not readable: %s\n' "$wheel" >&2
  exit 66
fi
for command in "$python" nm readelf; do
  if ! command -v "$command" >/dev/null 2>&1; then
    printf 'check-diagnostics-wheel: required command is unavailable: %s\n' \
      "$command" >&2
    exit 127
  fi
done

wheel_bytes=$(stat --format='%s' -- "$wheel")
if (( wheel_bytes >= max_wheel_bytes )); then
  printf 'check-diagnostics-wheel: wheel is %s bytes; limit is less than %s\n' \
    "$wheel_bytes" "$max_wheel_bytes" >&2
  exit 65
fi

work_dir=$(mktemp -d)
trap 'rm -rf -- "$work_dir"' EXIT

"$python" - "$wheel" <<'PY'
import sys
import zipfile
from pathlib import Path

wheel_path = Path(sys.argv[1])
if (
    "-cp310-abi3-" not in wheel_path.name
    or not wheel_path.name.endswith("_x86_64.whl")
):
    raise SystemExit("diagnostics wheel must target CPython abi3 on Linux x86_64")
required = {
    "deltafunnel/perfetto/capture-health",
    "deltafunnel/perfetto/capture-health.sql",
    "deltafunnel/perfetto/capture-workload",
    "deltafunnel/perfetto/delta-funnel-deep-system.pbtx",
    "deltafunnel/perfetto/delta-funnel-standard-streaming.pbtx",
    "deltafunnel/perfetto/delta-funnel-standard.pbtx",
}

with zipfile.ZipFile(wheel_path) as wheel:
    names = set(wheel.namelist())
    missing = sorted(required - names)
    if missing:
        raise SystemExit("missing diagnostics assets: " + ", ".join(missing))

    for name in ["capture-health", "capture-workload"]:
        asset = wheel.getinfo(f"deltafunnel/perfetto/{name}")
        mode = asset.external_attr >> 16
        if mode & 0o111 == 0:
            raise SystemExit(f"{name} is not executable in the wheel")

    if "deltafunnel/perfetto/delta-funnel-perfetto" in names:
        raise SystemExit("diagnostics CLI must not be duplicated as package data")
PY

"$python" -m venv "$work_dir/venv"
venv_python="$work_dir/venv/bin/python"
"$venv_python" -m pip install --disable-pip-version-check --no-cache-dir \
  --no-deps "$wheel" >/dev/null

native_module=$("$venv_python" - <<'PY'
import json
import os
import subprocess
import sys
import tempfile
from importlib.metadata import version
from importlib.resources import files
from pathlib import Path

import deltafunnel
import deltafunnel.deltafunnel as native

distribution_version = version("deltafunnel")
if deltafunnel.__version__ != distribution_version:
    raise SystemExit(
        "installed distribution and native module versions do not match: "
        f"{distribution_version} != {deltafunnel.__version__}"
    )

assets = files("deltafunnel").joinpath("perfetto")
config_names = [
    "delta-funnel-deep-system.pbtx",
    "delta-funnel-standard-streaming.pbtx",
    "delta-funnel-standard.pbtx",
]
required = [
    "capture-health",
    "capture-health.sql",
    "capture-workload",
    *config_names,
]
for name in required:
    if not assets.joinpath(name).is_file():
        raise SystemExit(f"installed diagnostics asset is missing: {name}")
for name in config_names:
    config_text = assets.joinpath(name).read_text()
    fields = [line.strip() for line in config_text.splitlines()]
    if fields.count("frequency: 100") != 1:
        raise SystemExit(f"installed diagnostics config has an invalid frequency: {name}")
    if fields.count("ring_buffer_read_period_ms: 100") != 1:
        raise SystemExit(
            f"installed diagnostics config has an invalid read period: {name}"
        )
    if fields.count("ring_buffer_pages: 256") != 1:
        raise SystemExit(
            f"installed diagnostics config has an invalid kernel buffer: {name}"
        )
    for category in [
        'enabled_categories: "delta_funnel.profile"',
        'enabled_categories: "delta_funnel.profile.context"',
    ]:
        if fields.count(category) != 1:
            raise SystemExit(
                f"installed diagnostics config is missing {category}: {name}"
            )

health = assets.joinpath("capture-health")
if not os.access(health, os.X_OK):
    raise SystemExit("installed capture-health is not executable")
subprocess.run([health, "--help"], check=True, stdout=subprocess.DEVNULL)

perfetto_cli = Path(sys.executable).with_name("delta-funnel-perfetto")
if not os.access(perfetto_cli, os.X_OK):
    raise SystemExit("installed delta-funnel-perfetto is not executable")
subprocess.run([perfetto_cli, "--help"], check=True, stdout=subprocess.DEVNULL)
subprocess.run([perfetto_cli, "help"], check=True, stdout=subprocess.DEVNULL)
subprocess.run(
    [perfetto_cli, "report", "--help"],
    check=True,
    stdout=subprocess.DEVNULL,
)
subprocess.run(
    [perfetto_cli, "inspect", "--help"],
    check=True,
    stdout=subprocess.DEVNULL,
)
invalid_command = subprocess.run(
    [perfetto_cli, "invalid"],
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
)
if invalid_command.returncode != 64:
    raise SystemExit("delta-funnel-perfetto did not reject an invalid command")

with tempfile.TemporaryDirectory() as temp_dir:
    temp = Path(temp_dir)
    records = [
        {
            "record_kind": "metadata",
            "record": {
                "capture_complete": True,
                "semantic_complete": True,
                "schema_version": 1,
                "sample_frequency_hz": 1000,
                "exact_time_unit": "nanoseconds",
                "sample_unit": "samples",
                "eligible_sample_count": 1,
                "direct_sample_count": 1,
                "ambiguous_sample_count": 0,
                "unattributed_sample_count": 0,
                "audit_error_count": 0,
            },
        },
        {
            "record_kind": "semantic",
            "record": {
                "semantic_id": 1,
                "parent_semantic_id": None,
                "operation_id": 1,
                "name": "Delta Funnel preview",
                "semantic_kind": "operation",
                "operation_kind": "preview",
                "stage_category": None,
                "stage_name": None,
                "activity": None,
                "start_ns": 10,
                "end_ns": 20,
                "duration_ns": 10,
                "time_semantics": "wall_clock",
                "result": "ok",
                "is_complete": True,
                "query_execution_id": None,
                "query_scope": None,
                "query_owner": None,
                "worker_lane_id": None,
                "worker_kind": None,
                "node_id": None,
                "parent_node_id": None,
                "operator_partition": None,
                "execution_stream_id": None,
                "stage_owner_id": None,
                "direct_sample_count": 1,
                "inclusive_sample_count": 0,
            },
        },
        {
            "record_kind": "function_self",
            "record": {
                "semantic_id": 1,
                "function_id": -1,
                "self_sample_count": 1,
            },
        },
    ]
    aggregate = temp.joinpath("aggregate.csv")
    aggregate.write_text(
        '"record_hex"\n'
        + "".join(
            f'"{json.dumps(record, separators=(",", ":")).encode().hex()}"\n'
            for record in records
        )
    )
    fake_trace_processor = temp.joinpath("trace_processor_shell")
    fake_trace_processor.write_text(
        "#!/usr/bin/env bash\n"
        "set -euo pipefail\n"
        "query=$(cat)\n"
        "if [[ $query == *delta_funnel_capture_health_input* && "
        "$query == *'CREATE PERFETTO TABLE delta_funnel_capture_health AS'* && "
        "$query == *record_kind* ]]; then\n"
        "  cat \"$DELTA_FUNNEL_TEST_AGGREGATE\"\n"
        "else\n"
        "  exit 65\n"
        "fi\n"
    )
    fake_trace_processor.chmod(0o700)
    trace = temp.joinpath("capture.pftrace")
    trace_bytes = b"\x0a\x00"
    trace.write_bytes(trace_bytes)
    report = temp.joinpath("capture.profile.html")
    generated = subprocess.run(
        [perfetto_cli, "report", trace, "--output", report],
        env={
            **os.environ,
            "TRACE_PROCESSOR_SHELL": str(fake_trace_processor),
            "DELTA_FUNNEL_TEST_AGGREGATE": str(aggregate),
        },
        check=True,
        capture_output=True,
        text=True,
    )
    if not generated.stdout.startswith("wrote "):
        raise SystemExit("ranked report command did not report its output")
    if trace.read_bytes() != trace_bytes:
        raise SystemExit("ranked report command modified its input trace")
    html = report.read_text()
    for marker in [
        "<!doctype html>",
        'id="profile-data"',
        "Delta Funnel preview",
        "Function metrics are sampled on-CPU observations",
    ]:
        if marker not in html:
            raise SystemExit(f"ranked report is missing {marker!r}")
    if trace_bytes.decode() in html or "http://" in html or "https://" in html:
        raise SystemExit("ranked report contains forbidden external or raw data")

capture = assets.joinpath("capture-workload")
if not os.access(capture, os.X_OK):
    raise SystemExit("installed capture-workload is not executable")
subprocess.run([capture, "--help"], check=True, stdout=subprocess.DEVNULL)
invalid_mode = subprocess.run(
    [
        capture,
        "--mode",
        "invalid",
        "--output",
        "unused.pftrace",
        "--",
        sys.executable,
    ],
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
)
if invalid_mode.returncode != 64:
    raise SystemExit("capture-workload did not reject an invalid mode")
invalid_sample_hz = subprocess.run(
    [
        capture,
        "--sample-hz",
        "999",
        "--output",
        "unused.pftrace",
        "--",
        sys.executable,
    ],
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
)
if invalid_sample_hz.returncode != 64:
    raise SystemExit("capture-workload did not reject an invalid sample frequency")

try:
    activated = deltafunnel.init_perfetto_diagnostics(wait_timeout_seconds=0.01)
except deltafunnel.DeltaFunnelError as error:
    if error.kind not in {"capture_timeout", "capture_unavailable"}:
        raise
else:
    if not activated:
        raise SystemExit("Perfetto diagnostics did not activate")

print(native.__file__)
PY
)

readelf -SW "$native_module" >"$work_dir/sections"
if grep -Fq '.debug_' "$work_dir/sections"; then
  printf 'check-diagnostics-wheel: native extension contains DWARF debug sections\n' >&2
  exit 65
fi

nm -C "$native_module" >"$work_dir/symbols"
for symbol in PerfettoProducerSystemInit delta_funnel::perfetto_profile; do
  if ! grep -Fq "$symbol" "$work_dir/symbols"; then
    printf 'check-diagnostics-wheel: required symbol is missing: %s\n' \
      "$symbol" >&2
    exit 65
  fi
done

printf 'diagnostics wheel check passed: %s bytes\n' "$wheel_bytes"
