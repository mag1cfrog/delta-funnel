#!/usr/bin/env bash
set -euo pipefail

usage() {
  printf 'Usage: %s [--ranked-audit] TRACE_PATH\n' "$0"
}

if [[ ${1:-} == --help || ${1:-} == -h ]]; then
  usage
  exit 0
fi
ranked_audit=false
if [[ ${1:-} == --ranked-audit ]]; then
  ranked_audit=true
  shift
fi
if [[ ${1:-} == --help || ${1:-} == -h ]]; then
  usage
  exit 0
fi
if [[ ${1:-} == -* ]]; then
  usage >&2
  exit 64
fi
if (( $# != 1 )); then
  usage >&2
  exit 64
fi

trace_path=$1
if [[ ! -f $trace_path || ! -r $trace_path ]]; then
  printf 'sample-correlation: trace is not a readable file: %s\n' \
    "$trace_path" >&2
  exit 66
fi

case $trace_path in
  /*) ;;
  *) trace_path=$PWD/$trace_path ;;
esac

trace_processor=${TRACE_PROCESSOR_SHELL:-trace_processor_shell}
if ! command -v "$trace_processor" >/dev/null 2>&1; then
  printf 'sample-correlation: trace processor is not executable: %s\n' \
    "$trace_processor" >&2
  exit 127
fi

script_dir=$(CDPATH= cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)
output=$({
  sed -n '1,$p' "$script_dir/sample-correlation.sql"
  if $ranked_audit; then
    sed -n '1,$p' "$script_dir/ranked-profile.sql"
    printf '%s\n' 'SELECT * FROM delta_funnel_ranked_aggregate_audit;'
  else
    printf '%s\n' 'SELECT * FROM delta_funnel_sample_correlation_audit;'
  fi
} | "$trace_processor" query --query-file - "$trace_path")
printf '%s\n' "$output"

audit_error_count=${output##*,}
if [[ ! $audit_error_count =~ ^[0-9]+$ ]]; then
  printf 'sample-correlation: trace processor returned an unexpected schema\n' >&2
  exit 65
fi
if (( audit_error_count != 0 )); then
  printf 'sample-correlation: found %s profile audit errors\n' \
    "$audit_error_count" >&2
  exit 65
fi
